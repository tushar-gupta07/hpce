Options -Indexes
DirectoryIndex index.php

RewriteEngine On
RewriteBase /rkhospital/admin/

# ── 1) Redirect .php URLs → clean URLs (301) ────────────────────────────────
RewriteCond %{THE_REQUEST} \s(/rkhospital/admin/[^\s?]*)\.php([?\s]|$)
RewriteRule ^ %1 [R=301,L,QSA]

# ── 2) Skip real files and directories ──────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ── 3) Add .php internally for extensionless requests ───────────────────────
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
